# Spelling Practice Application Environment Configuration

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-too
BCRYPT_ROUNDS=12

# Database
DB_PATH=./data/spelling.db
DB_BACKUP_INTERVAL=3600000
DB_MAX_CONNECTIONS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=5

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Features
ENABLE_ANALYTICS=true
ENABLE_GAMIFICATION=true
ENABLE_SPACED_REPETITION=true

# Security Headers
HSTS_MAX_AGE=31536000
CSP_REPORT_URI=
FRAME_ANCESTORS=none

# Performance
COMPRESSION_LEVEL=6
STATIC_CACHE_MAX_AGE=86400

# Application
APP_NAME=Spelling Practice
APP_VERSION=3.0.0
SUPPORT_EMAIL=admin@example.com